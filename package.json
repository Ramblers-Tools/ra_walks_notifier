{
  "name": "ra-walks-notifier",
  "version": "1.1.1-beta.13",
  "description": "Menu bar app for monitoring Ramblers Walks Manager review queues",
  "main": "src/main.js",
  "author": "Richard Higham <me@richyhigham.uk>",
  "license": "UNLICENSED",
  "scripts": {
    "app": "electron .",
    "test": "node --test",
    "build:mac:unsigned": "npm run clean:mac:xattrs && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg zip --publish never",
    "build:mac": "npm run clean:mac:xattrs && electron-builder --mac dmg zip",
    "build:mac:signed": "npm run clean:mac:xattrs && CSC_NAME=\"Richard Higham (9PG75A2TYV)\" electron-builder --mac dmg zip --publish never",
    "build:linux": "electron-builder --linux AppImage deb rpm --x64 --publish never",
    "build:linux:release": "electron-builder --linux AppImage deb rpm --x64",
    "build:win": "electron-builder --win nsis --x64 --publish never",
    "build:win:release": "electron-builder --win nsis --x64",
    "release:mac": "npm run build:mac:signed && npm run notary:submit",
    "release:mac:clean": "bash scripts/build-mac-release-clean.sh",
    "release:linux": "bash scripts/build-linux-release.sh",
    "release:win": "bash scripts/build-windows-release.sh",
    "release:validate": "bash scripts/validate-release-assets.sh",
    "release:publish": "bash scripts/publish-release.sh",
    "clean:mac:xattrs": "xattr -cr node_modules/electron/dist node_modules build assets src package.json 2>/dev/null || true",
    "notary:store": "xcrun notarytool store-credentials WalksManagerWatchNotary --apple-id YOUR_APPLE_ID --team-id 9PG75A2TYV --password YOUR_APP_SPECIFIC_PASSWORD",
    "notary:submit": "bash scripts/notarize-latest.sh"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "uk.richardhigham.walksmanagerwatch",
    "productName": "RA Walks Notifier",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json",
      "!node_modules/fsevents/**/*"
    ],
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "LSUIElement": true
      },
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": "Richard Higham (9PG75A2TYV)"
    },
    "win": {
      "icon": "assets/ramblers-logo.png",
      "artifactName": "RA-Walks-Notifier-${version}-${arch}-setup.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "RA-Walks-Notifier-${version}-${arch}-setup.${ext}"
    },
    "linux": {
      "category": "Utility",
      "icon": "assets/ramblers-logo.png",
      "artifactName": "RA-Walks-Notifier-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "sign": true,
      "title": "RA Walks Notifier ${version}",
      "iconSize": 96,
      "window": {
        "width": 520,
        "height": 320
      },
      "contents": [
        {
          "x": 150,
          "y": 150,
          "type": "file"
        },
        {
          "x": 370,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "afterPack": "build/afterPack.js",
    "publish": [
      {
        "provider": "github",
        "owner": "East-Cheshire-Ramblers",
        "repo": "ra_walks_notifier"
      }
    ]
  }
}
