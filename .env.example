# Email settings
SMTP_HOST=smtp.stackmail.com
SMTP_PORT=25
SMTP_SECURE=false
SMTP_USER=walksmanager@example.org.uk
SMTP_PASS=replace_me
MAIL_FROM_NAME=Walks Manager Watch
MAIL_FROM=walksmanager@example.org.uk
MAIL_TO=you@example.com,second@example.com

# Server mode only (src/server.js) - shared SMTP for every tenant.
# Example production values (SMTP2GO):
# SMTP_HOST=mail.smtp2go.com
# SMTP_PORT=2525
# SMTP_USER=your-smtp2go-user
# SMTP_PASS=replace_me
# MAIL_FROM=noreply@rawalksnotifier.ramblers.tools

# Server mode only - where per-tenant config/state/session/logs live.
# Defaults to data/tenants and logs/tenants under the repo root if unset.
# WMW_TENANTS_DIR=/opt/rawalksnotifier/data/tenants
# WMW_TENANT_LOGS_DIR=/opt/rawalksnotifier/logs/tenants

# Server mode only - HTTP port the API listens on (behind the Cloudflare Tunnel).
# PORT=7001
